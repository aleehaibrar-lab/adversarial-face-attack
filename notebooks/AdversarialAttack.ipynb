# Cell 1: Imports
import sys, os
sys.path.append(os.path.abspath('../src'))

import torch
from model import load_pretrained_resnet50   # matches model.py, not models.py
from attack import FGSMAttack
from utils import load_image, save_results

# Cell 2: Load Model
device = 'cuda' if torch.cuda.is_available() else 'cpu'
model = load_pretrained_resnet50(pretrained=True, device=device)

# Cell 3: Load Images
image_path = '../data/sample_images/test_image.jpg'
target_path = '../data/sample_images/target_image.jpg'   # you need a second image as the attack target

image = load_image(image_path)
target_image = load_image(target_path)

# Cell 4: Perform Attack
attacker = FGSMAttack(model, epsilon=0.3, device=device)
adversarial, perturbation = attacker.attack(image, target=target_image)

# Cell 5: Save Results
save_results(image, adversarial, perturbation, target_image, '../results/')
